  -moz-border-radius:0;
  border-radius:0
}
.header-mobile .hamburger .hamburger-box .hamburger-inner:before{
  width:20px;
  height:2px;
  top:6px
}
.header-mobile .hamburger .hamburger-box .hamburger-inner:after{
  top:12px;
  width:20px;
