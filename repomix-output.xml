<file path=".github/workflows/deploy-lbc.yml">
name: "Ops - Install LB Controller"

on:
  workflow_dispatch: # Chạy thủ công
  push:
    paths:
      - 'helm/lbc/**'

jobs:
  install-lbc:
    runs-on: ubuntu-latest
    permissions:
      id-token: write
      contents: read
    steps:
      - name: Checkout Code
        uses: actions/checkout@v3

      - name: Configure AWS Credentials
        uses: aws-actions/configure-aws-credentials@v2
        with:
          role-to-assume: ${{ secrets.AWS_ROLE_ARN }}
          aws-region: ap-southeast-1

      - name: Update Kubeconfig
        run: aws eks update-kubeconfig --region ap-southeast-1 --name devsecops-eks-cluster

      - name: Install AWS Load Balancer Controller
        run: |
          helm repo add eks https://aws.github.io/eks-charts
          helm repo update
          helm upgrade --install aws-load-balancer-controller eks/aws-load-balancer-controller \
            -n kube-system \
            -f helm/lbc/values.yaml
</file>

<file path=".github/workflows/infrastructure-vpc.yml">
name: "Infrastructure - VPC"

on:
  push:
    paths:
      - 'terraform/vpc/**'
    branches:
      - main
  workflow_dispatch: # Cho phép bấm nút chạy bằng tay

permissions:
  id-token: write # Bắt buộc để dùng OIDC
  contents: read  # Bắt buộc để đọc code

jobs:
  iac-security-scan:
    name: "IaC Security Scan"
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3

      - name: Run Checkov
        uses: bridgecrewio/checkov-action@master
        with:
          directory: terraform/vpc
          framework: terraform
          soft_fail: false # Nếu có lỗi bảo mật nghiêm trọng, STOP pipeline ngay lập tức!
          # Đây là tư duy DevSecOps: Ngăn chặn hạ tầng không an toàn ngay từ đầu.

  deploy-vpc:
    name: "Deploy VPC"
    needs: iac-security-scan
    runs-on: ubuntu-latest
    env:
      TF_STATE_BUCKET: "trung-devsecops-eks-tfstate-prod" # Thay tên bucket của bạn
    steps:
      - uses: actions/checkout@v3

      - name: Configure AWS credentials
        uses: aws-actions/configure-aws-credentials@v2
        with:
          role-to-assume: ${{ secrets.AWS_ROLE_ARN }}
          aws-region: ap-southeast-1

      - name: Setup Terraform
        uses: hashicorp/setup-terraform@v2

      - name: Terraform Init
        run: |
          cd terraform/vpc
          terraform init \
            -backend-config="bucket=${{ env.TF_STATE_BUCKET }}" \
            -backend-config="key=vpc/terraform.tfstate" \
            -backend-config="region=ap-southeast-1" \
            -backend-config="dynamodb_table=devsecops-tf-locks"

      - name: Terraform Plan
        run: |
          cd terraform/vpc
          terraform plan

      - name: Terraform Apply
        if: github.ref == 'refs/heads/main'
        run: |
          cd terraform/vpc
          terraform apply -auto-approve
</file>

