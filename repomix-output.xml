name: "App - Deploy to EKS"

on:
  workflow_dispatch: # Cho phép bấm nút chạy thủ công
  push:
    paths:
      - 'kubernetes/**' # Tự động chạy khi bạn sửa file manifest

jobs:
  deploy:
    runs-on: ubuntu-latest
    permissions:
      id-token: write
      contents: read
    steps:
      - name: Checkout Code
        uses: actions/checkout@v3

      - name: Configure AWS Credentials
        uses: aws-actions/configure-aws-credentials@v2
        with:
          role-to-assume: ${{ secrets.AWS_ROLE_ARN }}
          aws-region: ap-southeast-1

      - name: Update Kubeconfig
        run: aws eks update-kubeconfig --region ap-southeast-1 --name devsecops-eks-cluster

      - name: Deploy Manifests
        run: |
          # Áp dụng tất cả các file trong thư mục kubernetes theo thứ tự
          kubectl apply -f kubernetes/service-account.yaml
          kubectl apply -f kubernetes/secret-store.yaml
          kubectl apply -f kubernetes/external-secret.yaml
          kubectl apply -f kubernetes/backend-deployment.yaml
          kubectl apply -f kubernetes/backend-service.yaml
          kubectl apply -f kubernetes/frontend-deployment.yaml
          kubectl apply -f kubernetes/ingress.yaml
          kubectl apply -f kubernetes/mysql-configmap.yaml
          kubectl apply -f kubernetes/mysql.yaml
          kubectl apply -f kubernetes/backend-hpa.yaml
</file>

<file path="Fullstack-Ecommerce-Web/03-frontend/Dockerfile">
# Stage 1: Build Angular App
FROM node:18-alpine AS build
WORKDIR /app
COPY package*.json ./
# Sửa lại dòng số 5 trong Stage 1
RUN npm install --ignore-scripts
COPY . .
RUN npm run build --configuration=production

# Stage 2: Serve với Nginx (Bản Alpine để giảm thiểu lỗ hổng)
FROM nginx:alpine
RUN apk update && apk upgrade --no-cache

# Bảo mật: Đổi chủ sở hữu thư mục cache và pid để Nginx chạy được với user thường
RUN touch /var/run/nginx.pid && \
    chown -R nginx:nginx /var/run/nginx.pid /var/cache/nginx /var/log/nginx /etc/nginx/conf.d

# Chuyển sang dùng User nginx (đã có sẵn trong image alpine)
USER nginx

# Copy file đã build từ stage 1
COPY --from=build /app/dist/angular-ecommerce /usr/share/nginx/html

# Copy file cấu hình Nginx tùy chỉnh (Xem bước dưới để tạo file này)
# COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
</file>

